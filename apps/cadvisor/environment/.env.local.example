# CadVisor — Local Development (copy to .env.local)
# This file is an example. Copy it:
#   cp environment/.env.local.example environment/.env.local
#
# .env.local is gitignored — safe for secrets
VITE_APP_NAME=CadVisor
VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:3001
VITE_ENABLE_CAD=true
VITE_ENABLE_DASHBOARD=true
VITE_ENABLE_BILLING=false
VITE_LOG_LEVEL=debug
