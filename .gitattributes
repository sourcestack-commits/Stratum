# Normalize all text files to LF line endings in the repository.
# This prevents Windows vs Linux line-ending drift that breaks prettier --check on CI.
* text=auto eol=lf

# Shell scripts and config files must be LF explicitly
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.css      text eol=lf
*.html     text eol=lf

# Windows batch scripts — must stay CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Binary files — do not touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.mp4      binary
*.mov      binary
*.zip      binary
*.pdf      binary

# Lockfiles — generated, do not diff-format
pnpm-lock.yaml linguist-generated=true
